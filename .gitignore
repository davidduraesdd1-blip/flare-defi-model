# ── API keys / secrets ────────────────────────────────────────────────────────
*.env
ANTHROPIC_API_KEY*

# ── Sensitive data ────────────────────────────────────────────────────────────
data/alerts_config.json      # contains SMTP/Telegram credentials — never commit
data/history.json            # large scan history — regenerated by scheduler
data/positions.json          # personal portfolio positions
data/monitor_digest.json     # local monitor state
data/quick_cache.json        # ephemeral scan cache
data/*.tmp                   # atomic write temp files

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
