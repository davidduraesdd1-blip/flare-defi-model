# ── Git internals (filter-branch / rewrite artifacts) ─────────────────────────
.git-rewrite/

# ── Secrets & credentials (NEVER commit these) ────────────────────────────────
.env
*.env
ANTHROPIC_API_KEY*
.streamlit/secrets.toml
# contains SMTP credentials + generic webhook URL — NEVER commit
# (Telegram + Discord senders were removed 2026-04-18 for this reason)
data/alerts_config.json
data/feedback_checkpoint.json

# ── Database & runtime state ──────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
# Audit R8h: catch any wallet file that lands outside data/agent/
wallets.enc
# Cross-app state files (Phase 3/4 safety + reservation ledgers)
data/pending_multisig.json
data/circuit_state.json
data/wallet_reservations.json
data/cross_app_positions.json

# ── Agent wallet files (NEVER commit — contain encrypted private keys) ────────
data/agent/wallets.enc
data/agent/*.enc
data/agent/agent.db
data/agent/agent_state.json

# ── Runtime data files (auto-generated, personal data) ───────────────────────
data/history.json
data/positions.json
data/monitor_digest.json
data/quick_cache.json
data/scan_cache.json
data/feedback_cache.json
data/user_feedback.jsonl
data/*.tmp
data/*.bak

# ── Generated output files ────────────────────────────────────────────────────
*.csv
*.xlsx
*.pdf
*.png
*.log
logs/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
