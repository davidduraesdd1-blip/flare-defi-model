# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in your keys.
# secrets.toml is gitignored — never commit the real file.
#
# Key rotation tiers:
#   Tier 1 (critical — rotate immediately if leaked): ANTHROPIC_API_KEY
#   Tier 2 (high — rotate within 24h): DEFI_SENTRY_DSN
#   Tier 3 (medium — rotate within 1 week): DEFI_COINGECKO_API_KEY
#   Tier 4 (low — rotate at next cycle): CDP keys

# ─── Tier 1: AI / LLM ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = ""          # https://console.anthropic.com/

# ─── Tier 2: Infrastructure ───────────────────────────────────────────────────
DEFI_SENTRY_DSN = ""            # https://sentry.io/  (free tier)

# ─── Tier 3: Market Data ──────────────────────────────────────────────────────
DEFI_COINGECKO_API_KEY = ""     # https://www.coingecko.com/en/api  (Pro)

# ─── Tier 4: Web3 / CDP ───────────────────────────────────────────────────────
CDP_API_KEY_NAME = ""           # https://portal.cdp.coinbase.com/
CDP_API_KEY_PRIVATE_KEY = ""
AGENTKIT_NETWORK = "base-mainnet"
