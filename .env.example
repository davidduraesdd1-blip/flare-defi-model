# ══════════════════════════════════════════════════════════════════════════════
# DeFi Model — Environment Variables
# Copy this file to .env and fill in your keys. Never commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── AI (unlocks intent classification, ecosystem digest, Intelligence tab AI) ─
ANTHROPIC_API_KEY=sk-ant-api03-...          # console.anthropic.com → API Keys
ANTHROPIC_ENABLED=true                      # set to "false" to disable all AI features without removing key

# ── Market Data ───────────────────────────────────────────────────────────────
DEFI_COINGECKO_API_KEY=CG-...              # coingecko.com/en/api — higher rate limits
DEFI_COINMETRICS_API_KEY=...               # coinmetrics.io/community (free) — BTC MVRV/SOPR; fixes 403 on Streamlit Cloud

# ── Wallet & Portfolio ────────────────────────────────────────────────────────
ZERION_API_KEY=...                         # zerion.io/developers — cross-chain wallet positions

# ── Alerts & Notifications ────────────────────────────────────────────────────
# Option A — Quick env var webhook (Discord or Telegram):
DEFI_WEBHOOK_URL=https://discord.com/api/webhooks/...   # Discord: Server Settings → Integrations → Webhooks
                                                         # Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage
DEFI_TELEGRAM_CHAT_ID=...                  # Required when DEFI_WEBHOOK_URL points to Telegram. Get from @userinfobot.

# Option B — Configure via the Settings tab in the UI (stores in data/alerts_config.json)

# ── On-Chain Execution (AgentKit) ─────────────────────────────────────────────
CDP_API_KEY_NAME=...                       # portal.cdp.coinbase.com (free) — AgentKit wallet section
CDP_API_KEY_PRIVATE_KEY=...
AGENTKIT_NETWORK=base-mainnet              # default: base-mainnet

# ── Error Monitoring ──────────────────────────────────────────────────────────
DEFI_SENTRY_DSN=https://...@sentry.io/... # sentry.io (free tier)

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_TZ=America/Denver               # default timezone for scheduled scans
